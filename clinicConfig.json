                "items":  [
                              {
                                  "q":  {
                                            "de":  "Wie oft sollte ich zur Zahnärztin oder zum Zahnarzt gehen?",
                                            "en":  "How often should I visit the dentist?"
                                        },
                                  "a":  {
                                            "de":  "Wir empfehlen Kontrolle und professionelle Reinigung alle 6 Monate. Je nach Mundgesundheit kann Ihr Team häufigere Termine vorschlagen.",
                                            "en":  "We recommend a check-up and professional cleaning every 6 months, though your dentist may suggest more frequent visits based on your oral health."
                                        }
                              },
                              {
                                  "q":  {
                                            "de":  "Sind Zahnbehandlungen schmerzhaft?",
                                            "en":  "Are dental treatments painful?"
                                        },
                                  "a":  {
                                            "de":  "Moderne Techniken und Betäubung machen Behandlungen angenehm und nahezu schmerzfrei.",
                                            "en":  "Modern techniques and anesthesia keep treatments comfortable and virtually pain-free."
                                        }
                              },
                              {
                                  "q":  {
                                            "de":  "Bieten Sie Zahnimplantate an?",
                                            "en":  "Do you offer dental implants?"
                                        },
                                  "a":  {
                                            "de":  "Ja, wir bieten komplette Implantatlösungen mit digitaler Planung.",
                                            "en":  "Yes, we provide full implant solutions with digital planning."
                                        }
                              },
                              {
                                  "q":  {
                                            "de":  "Behandeln Sie auch Kinder?",
                                            "en":  "Do you treat children?"
                                        },
                                  "a":  {
                                            "de":  "Ja, selbstverständlich - wir bieten einfühlsame Kinderzahnmedizin.",
                                            "en":  "Absolutely - we have dedicated pediatric care."
                                        }
                              }
                          ]
